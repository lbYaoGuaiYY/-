# 开发环境：本机素材服务。
VITE_APP_ENV=development
VITE_ASSET_SERVICE_URL=http://127.0.0.1:7000
VITE_ASSET_EDITOR_TOKEN=
VITE_ASSET_SERVICE_EVENTS=0

# Server-only HMAC secret for issuing short-lived anonymous upload capabilities.
# Never prefix this with VITE_ or place it in a frontend build environment.
QINGSHE_SUBMISSION_TOKEN=

# Only set when the asset service receives requests from a known reverse proxy
# and its forwarded client-IP header should be trusted (IP or CIDR, comma-separated).
QINGSHE_TRUSTED_PROXY_IPS=

# Dedicated token required for processing-node enrollment; never reuse admin/editor tokens.
QINGSHE_PROCESSING_REGISTRATION_TOKEN=

# 素材管理页只在本机运维环境使用，普通编辑器不要填写 Admin Token。
