{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "轻设",
  "version": "0.1.0",
  "identifier": "com.qingshe.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4174",
    "beforeDevCommand": "pnpm dev:tauri",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "轻设",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "iOS": {
      "minimumSystemVersion": "15.0"
    }
  }
}
