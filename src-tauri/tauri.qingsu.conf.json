{
  "productName": "轻素",
  "identifier": "com.qingshe.assetadmin",
  "build": {
    "frontendDist": "../dist-asset-admin",
    "devUrl": "http://127.0.0.1:4175/asset-admin.html",
    "beforeDevCommand": "pnpm dev:asset-admin:tauri",
    "beforeBuildCommand": "pnpm build:asset-admin"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "轻素 · 素材管理",
        "width": 1360,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/qingsu/generated/32x32.png",
      "icons/qingsu/generated/128x128.png",
      "icons/qingsu/generated/128x128@2x.png",
      "icons/qingsu/generated/icon.icns",
      "icons/qingsu/generated/icon.ico"
    ]
  }
}
