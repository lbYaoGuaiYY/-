{
  "name": "qingshe-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "canvas"
    ]
  },
  "scripts": {
    "app:dev": "vite --mode app",
    "app:dev:tauri": "vite --mode app --port 4174",
    "app:build": "tsc --noEmit && vite build --mode app",
    "app:preview": "vite preview",
    "app:desktop:dev": "tauri dev",
    "app:desktop:build": "tauri build && node scripts/finalize-desktop-app-build.mjs",
    "app:mac:build": "CARGO_BUILD_JOBS=1 CARGO_PROFILE_RELEASE_STRIP=none CARGO_PROFILE_RELEASE_LTO=false tauri build --bundles app,dmg && node scripts/finalize-desktop-app-build.mjs",
    "app:windows:build": "tauri build --bundles nsis && node scripts/finalize-desktop-app-build.mjs",
    "app:ios:init": "tauri ios init && pnpm app:ios:sync",
    "app:ios:sync": "node scripts/prepare-ios-project.mjs",
    "app:ios:dev": "pnpm app:ios:sync && PATH=\"$PWD/scripts:$PATH\" QINGSHE_IOS_MIN_VERSION=15.0 tauri ios dev --open",
    "app:ios:build": "pnpm app:ios:sync && PATH=\"$PWD/scripts:$PATH\" QINGSHE_IOS_MIN_VERSION=15.0 tauri ios build --debug --target aarch64-sim --no-sign",
    "asset-panel:dev": "vite --mode asset-admin",
    "asset-panel:build": "pnpm extension:build && tsc --noEmit && vite build --mode asset-admin && node scripts/finalize-asset-admin-build.mjs",
    "processor:web:dev": "vite --mode processor --port 4176",
    "processor:web:build": "tsc --noEmit && vite build --mode processor",
    "processor:dev": "tauri dev --config src-tauri/tauri.processor.conf.json --features processor",
    "processor:build": "node scripts/build-processing-agent.mjs",
    "extension:build": "node scripts/build-browser-extension.mjs",
    "boundaries:check": "node scripts/check-product-boundaries.mjs",
    "build:all": "pnpm app:build && pnpm asset-panel:build && pnpm processor:web:build && pnpm boundaries:check --artifacts",
    "dev": "pnpm app:dev",
    "build": "pnpm app:build",
    "tauri": "tauri",
    "dev:e2e": "vite --mode e2e",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:endpoints": "node scripts/check-production-endpoints.mjs",
    "licenses:check": "pnpm licenses list --prod --json | node scripts/check-production-licenses.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "pnpm boundaries:check && pnpm typecheck && pnpm test && pnpm check && pnpm build:all && pnpm test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-virtual": "3.13.12",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "dexie": "4.4.4",
    "fabric": "7.4.0",
    "fflate": "^0.8.3",
    "ky": "^2.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react-grab": "^0.1.48",
    "react-scan": "^0.5.7",
    "typescript": "^7.0.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  }
}
