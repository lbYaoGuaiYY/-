{
  "name": "qingshe-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "pnpm": {
    "ignoredBuiltDependencies": [
      "canvas"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:tauri": "vite --port 4174",
    "dev:asset-admin:tauri": "vite --mode asset-admin --port 4175",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "CARGO_BUILD_JOBS=1 CARGO_PROFILE_RELEASE_STRIP=none CARGO_PROFILE_RELEASE_LTO=false tauri build --bundles app,dmg",
    "qingshe:ios:init": "tauri ios init && node scripts/prepare-ios-project.mjs",
    "qingshe:ios:dev": "tauri ios dev --open",
    "qingshe:ios:build": "node scripts/prepare-ios-project.mjs && PATH=\"$PWD/scripts:$PATH\" QINGSHE_IOS_MIN_VERSION=15.0 tauri ios build --debug --target aarch64-sim --no-sign",
    "qingsu:dev": "tauri dev --config src-tauri/tauri.qingsu.conf.json",
    "qingsu:build": "tauri build --config src-tauri/tauri.qingsu.conf.json",
    "dev:asset-admin": "vite --mode asset-admin",
    "dev:e2e": "vite --mode e2e",
    "dev:assets": "powershell -ExecutionPolicy Bypass -File scripts/dev-with-assets.ps1",
    "assets:server": "uv run tools/asset_admin/server.py",
    "build": "tsc --noEmit && vite build",
    "build:asset-admin": "tsc --noEmit && vite build --mode asset-admin && node scripts/finalize-asset-admin-build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "licenses:check": "pnpm licenses list --prod --json | node scripts/check-production-licenses.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "pnpm typecheck && pnpm test && pnpm check && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@phosphor-icons/react": "2.1.10",
    "@tanstack/react-virtual": "3.13.12",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "dexie": "4.4.4",
    "fabric": "7.4.0",
    "fflate": "^0.8.3",
    "ky": "^2.0.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "react-grab": "^0.1.48",
    "react-scan": "^0.5.7",
    "typescript": "^7.0.2",
    "vite": "8.1.4",
    "vitest": "^4.1.10"
  }
}
