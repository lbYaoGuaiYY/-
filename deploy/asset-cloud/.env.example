QINGSHE_TRUSTED_PROXY_IPS=172.30.232.3/32
QINGSHE_PROCESSING_REGISTRATION_TOKEN=replace-with-a-dedicated-processing-registration-token
QINGSHE_ALLOWED_ORIGINS=https://assets.xiduoduo.top,http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:4174,http://localhost:4174,tauri://localhost,http://tauri.localhost
