#!/usr/bin/env node

import { execFileSync, spawnSync } from "node:child_process"
import {
  mkdirSync,
  mkdtempSync,
  readdirSync,
  readFileSync,
  rmSync,
  symlinkSync,
  writeFileSync,
} from "node:fs"
import { tmpdir } from "node:os"
import { dirname, join, relative } from "node:path"

import {
  getIosSwiftLinkSearchPath,
  getIosSwiftProductsPath,
  getIosSwiftTarget,
} from "./ios-swift-target.mjs"

const N_STAB = 0xe0
const N_PEXT = 0x10
const N_TYPE = 0x0e
const N_EXT = 0x01
const N_SECT = 0x0e
const MH_MAGIC_64 = 0xfeedfacf

const args = process.argv.slice(2)
const realSwift =
  process.env.QINGSHE_REAL_SWIFT ??
  execFileSync("xcrun", ["--find", "swift"], {
    encoding: "utf8",
  }).trim()

let swiftArgs = args
let iosSwiftTarget
let swiftPackageBuildPath
let swiftPackageConfiguration = "debug"
if (args[0] === "build" && process.env.CARGO_CFG_TARGET_OS === "ios") {
  const filteredArgs = ["build"]
  for (let index = 1; index < args.length; index += 1) {
    if (args[index] === "--arch") {
      index += 1
      continue
    }
    filteredArgs.push(args[index])
  }

  const swiftTarget = getIosSwiftTarget(
    process.env.TARGET ?? "",
    process.env.QINGSHE_IOS_MIN_VERSION ?? "15.0",
  )
  iosSwiftTarget = swiftTarget
  swiftArgs = ["build", "--triple", swiftTarget, ...filteredArgs.slice(1)]

  const buildPathIndex = filteredArgs.indexOf("--build-path")
  if (buildPathIndex !== -1) swiftPackageBuildPath = filteredArgs[buildPathIndex + 1]

  const configurationIndex = filteredArgs.findIndex(
    (argument) => argument === "-c" || argument === "--configuration",
  )
  if (configurationIndex !== -1) {
    swiftPackageConfiguration = filteredArgs[configurationIndex + 1] ?? "debug"
  }
}

const result = spawnSync(realSwift, swiftArgs, {
  env: process.env,
  stdio: "inherit",
})

if (result.error) throw result.error

if (result.status === 0 && iosSwiftTarget && swiftPackageBuildPath) {
  const productsDirectory = getIosSwiftProductsPath(
    swiftPackageBuildPath,
    iosSwiftTarget,
    swiftPackageConfiguration,
  )
  const linkDirectory = join(
    swiftPackageBuildPath,
    getIosSwiftLinkSearchPath(iosSwiftTarget, swiftPackageConfiguration),
  )
  mkdirSync(dirname(linkDirectory), { recursive: true })
  rmSync(linkDirectory, { force: true, recursive: true })
  symlinkSync(relative(dirname(linkDirectory), productsDirectory), linkDirectory, "dir")

  // Xcode 27 / Swift 6.4 can leave @_cdecl exports as private-external, which
  // makes Rust fail to resolve Tauri/iOS bridge symbols at link time.
  globalizeIosCdeclExports(productsDirectory)
}

process.exit(result.status ?? 1)

function shouldGlobalizeSymbol(name, type) {
  if (!name.startsWith("_") || name.startsWith("_$") || name.startsWith("__")) return false
  if (name.startsWith("_OBJC_") || name.startsWith("_objc_")) return false
  if ((type & N_TYPE) !== N_SECT || (type & N_STAB) !== 0) return false

  // Only promote private-external @_cdecl exports. Pure locals such as
  // _block_copy_helper must stay local or Xcode 27 ld asserts on duplicates.
  if ((type & N_PEXT) === 0) return false
  if ((type & N_EXT) !== 0 && (type & N_PEXT) === 0) return false

  const body = name.slice(1)
  return body.length > 0 && /^[A-Za-z_][A-Za-z0-9_]*$/.test(body)
}

function readU32(view, offset) {
  return view.getUint32(offset, true)
}

function globalizeMachOObject(buffer) {
  if (buffer.length < 32) return 0
  const view = new DataView(buffer.buffer, buffer.byteOffset, buffer.byteLength)
  if (readU32(view, 0) !== MH_MAGIC_64) return 0

  const ncmds = readU32(view, 16)
  let offset = 32
  let symoff
  let nsyms
  let stroff

  for (let index = 0; index < ncmds; index += 1) {
    const cmd = readU32(view, offset)
    const cmdsize = readU32(view, offset + 4)
    if (cmd === 2) {
      symoff = readU32(view, offset + 8)
      nsyms = readU32(view, offset + 12)
      stroff = readU32(view, offset + 16)
    }
    offset += cmdsize
  }

  if (symoff === undefined || nsyms === undefined || stroff === undefined) return 0

  let changed = 0
  for (let index = 0; index < nsyms; index += 1) {
    const entry = symoff + index * 16
    const nStrx = readU32(view, entry)
    const nType = buffer[entry + 4]
    let end = stroff + nStrx
    while (end < buffer.length && buffer[end] !== 0) end += 1
    const name = Buffer.from(buffer.subarray(stroff + nStrx, end)).toString("utf8")
    if (!shouldGlobalizeSymbol(name, nType)) continue

    const nextType = ((nType & ~N_PEXT & ~N_STAB) | N_EXT | N_SECT) & 0xff
    if (nextType === nType) continue
    buffer[entry + 4] = nextType
    changed += 1
  }

  return changed
}

function globalizeObjectFile(path) {
  const buffer = Buffer.from(readFileSync(path))
  const changed = globalizeMachOObject(buffer)
  if (changed > 0) writeFileSync(path, buffer)
  return changed
}

function globalizeStaticArchive(archivePath) {
  const tempDirectory = mkdtempSync(join(tmpdir(), "qingshe-swift-globalize-"))
  try {
    execFileSync("ar", ["x", archivePath], { cwd: tempDirectory, stdio: "ignore" })
    const objectFiles = readdirSync(tempDirectory)
      .filter((entry) => entry.endsWith(".o"))
      .map((entry) => join(tempDirectory, entry))
      .sort()

    let changed = 0
    for (const objectFile of objectFiles) changed += globalizeObjectFile(objectFile)
    if (objectFiles.length === 0) return 0

    const rebuiltArchive = join(tempDirectory, "rebuilt.a")
    execFileSync("libtool", ["-static", "-o", rebuiltArchive, ...objectFiles], {
      stdio: "ignore",
    })
    writeFileSync(archivePath, readFileSync(rebuiltArchive))
    return changed
  } finally {
    rmSync(tempDirectory, { recursive: true, force: true })
  }
}

function globalizeIosCdeclExports(productsDirectory) {
  let changed = 0
  for (const entry of readdirSync(productsDirectory, { withFileTypes: true })) {
    const path = join(productsDirectory, entry.name)
    if (entry.isFile() && entry.name.endsWith(".o")) changed += globalizeObjectFile(path)
    if (entry.isFile() && entry.name.endsWith(".a")) changed += globalizeStaticArchive(path)
  }
  if (changed > 0) {
    process.stderr.write(
      `[qingshe] globalized ${changed} iOS Swift @_cdecl export symbol(s) for Rust linking\n`,
    )
  }
}
